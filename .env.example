PORT=3000
MONGODB_URI=mongodb://localhost:27017/celebrity-fan-site
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Stripe (test keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# CoinGate (sandbox from https://sandbox.coingate.com)
COINGATE_API_TOKEN=your_coingate_sandbox_token
COINGATE_ENVIRONMENT=sandbox

# Cloudinary (free at cloudinary.com — for image uploads that survive deploys)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# App
APP_URL=http://localhost:3000
